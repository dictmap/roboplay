      "passed": true
    },
    {
      "name": "chunk_refresh_logic_detects_empty_or_exhausted_chunk",
      "passed": true
    },
    {
      "name": "chunk_refresh_logic_reuses_non_exhausted_chunk",
      "passed": true
    },
    {
      "name": "server_query_estimate_respects_horizon",
      "passed": true
    },
    {
      "name": "world_state_supports_batched_queries_and_predicate_reset",
      "passed": true
    },
    {
      "name": "event_tracker_records_failure_events_and_respects_masks",
      "passed": true
    },
    {
      "name": "hdf5_is_registered_as_score_source",
      "passed": true
    },
    {
